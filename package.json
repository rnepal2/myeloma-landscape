{
  "name": "myeloma-landscape-radar",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "data:refresh": "python3 scripts/refresh_data.py",
    "data:check": "python3 scripts/validate_data.py",
    "test": "vitest run",
    "typecheck": "tsc -b --pretty false",
    "format": "prettier --write 'src/**/*.{ts,tsx,css}' vite.config.ts",
    "format:check": "prettier --check 'src/**/*.{ts,tsx,css}' vite.config.ts",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "@fontsource-variable/manrope": "^5.2.8",
    "@fontsource/newsreader": "^5.2.8",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.18.1",
    "recharts": "^3.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "prettier": "^3.9.5",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.7.2",
    "vite": "^7.0.0",
    "vitest": "^3.0.0",
    "wrangler": "^4.0.0"
  }
}
